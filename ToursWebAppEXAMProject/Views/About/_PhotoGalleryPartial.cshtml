@model AboutPageVersion

<a name="photo_gallery"></a>
<div>
    <div>
        <h1 class="title">@Model.PhotoGalleryTitle</h1>
    </div>
    <div>
        <h4 class="short-description">@Model.PhotoGalleryShortDescription</h4>
    </div>
    <div class="titleImage">
        <img src="@Model.PhotoGalleryImagePath" alt="@Model.PhotoGalleryImagePath" />
    </div>
    <div class="full-description">@Html.Raw(@Model.PhotoGalleryFullDescription)</div>
    <div class="photoGallery">
        
        @foreach (var image in Model.CollectionImages)
        {
            <div class="titleImage">
                <img src="@image.ImagePath" alt="@image.ImagePath" />
            </div>
        }
    </div>
    <hr class="horizontal-line" />
</div>
