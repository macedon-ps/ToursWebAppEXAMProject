@model EditAboutPageViewModel

<a name="details"></a>
<div>
    <div>
        <h1 class="title">@Model.AboutPageVersion.DetailsTitle</h1>
    </div>
    <div>
        <h4 class="short-description">@Model.AboutPageVersion.DetailsShortDescription</h4>
    </div>
    <div class="titleImage40">
        <img src="@Model.AboutPageVersion.DetailsImagePath" alt="@Model.AboutPageVersion.DetailsImagePath" class="image-editAboutPage" />
    </div>
    <div class="full-description">@Html.Raw(@Model.AboutPageVersion.DetailsFullDescription)</div>

    <h3>Название компании:</h3>
    <p class="copy-allowed">@ConfigData.CompanyName</p>
    <h3>Электронная почта:</h3>
    <p class="copy-allowed">@ConfigData.CompanyEmail</p>
    <h3>Контактный телефон:</h3>
    <p class="copy-allowed">@ConfigData.CompanyPhone</p>
    <hr class="horizontal-line" />
</div>