@{
    ViewData["Title"] = "Успешное удаление";
}

<div class="editPage">
    
    @if (Model is AboutPageVersion)
    {
        @await Html.PartialAsync("../About/_AboutButtonMenuPartial")

        <div class="editHeader">

            <h3 class="title">Удаление объекта прошло  успешно!</h3>
            <h4 class="title">Данные удаленного объекта:</h4>
            <hr class="horizontal-line" />
            <br />
            <div>
                
                <div class="padding_bottom_2 displayFlex">
                    Версия страницы: v.@Model.Keyword
                </div>
                <div class="padding_bottom_2 displayFlex">
                    Id: @Model.Id
                </div>
                <div class="padding_bottom_2 displayFlex">
                    Время создания/редактирования: @Model.DateAdded
                </div>
         
            </div>
        </div>
    }
    @if (Model is Blog || Model is City || Model is Country || Model is New || Model is Product)
    {
        @await Html.PartialAsync("../Edit/_EditButtonMenuPartial")

        <div class="editHeader">

            <h3 class="title">Удаление объекта прошло  успешно!</h3>
            <h4 class="title">Данные удаленного объекта:</h4>
            <hr class="horizontal-line" />
            <br />
            <div>
                
                <div class="padding_bottom_2 displayFlex">
                    Название: @Model.Name
                </div>
                <div class="padding_bottom_2 displayFlex">
                    Краткое описание: @Model.ShortDescription
                </div>
                <div class="padding_bottom_2 displayFlex">
                    Полное описание: @Model.FullDescription
                </div>
                <div class="padding_bottom_2 displayFlex">
                    Титульная картинка: @Model.TitleImagePath
                </div>
                <div class="padding_bottom_2 displayFlex">
                    Время создания/редактирования: @Model.DateAdded
                </div>
                
            </div>
        </div>
    }
</div>
