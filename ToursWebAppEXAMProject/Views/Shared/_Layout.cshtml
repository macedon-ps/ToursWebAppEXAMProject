<!DOCTYPE html>
<html lang="en">
    <head>
        @await Html.PartialAsync("_MetatagsPartial")
        @await Html.PartialAsync("_CssPartial")
    </head>
<body>
    <div id="page-wrapper">
        @* TODO: Создать хедер. Пока заглушка  *@
        @await Html.PartialAsync("_HeaderPartial")
        <div id="main">
			<div class="container palms"> 
				<div class="row main-row" >
					<div class="col-10 col-12-medium">
                        @RenderBody()
                    </div>
                    @* TODO: Создать боковую часть "_SidePartial". Пока заглушка  *@
                    <div class="col-2 col-12-medium">
                        @await Html.PartialAsync("_SidePartial")
                    </div>
                </div>
                 @* TODO: Создать футер. Пока заглушка  *@
                @await Html.PartialAsync("_FooterPartial")
             </div>
        </div>
    </div>
        
    @await Html.PartialAsync("_ScriptsPartial")
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
