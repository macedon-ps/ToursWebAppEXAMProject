@*
    Подключение скриптов
*@
@*
    Объединили в один следующие скрипты:  
    jquery.min.js, 
    browser.min.js, 
    breakpoints.min.js, 
    util.js, 
    main.js
     <script src="~/js/scripts.min.js" asp-append-version="true"></script>
*@
<script>
    
    const burgerBtn = document.getElementById("burgerBtn");
    const nav = document.getElementById("nav");
    const container = document.getElementById("container-header");
    const page = document.getElementById("page");
    
    burgerBtn.addEventListener("click", () =>
    {
        nav.classList.toggle("active");
        container.classList.toggle("container-header-active");
        page.classList.toggle("page-down");
    });

</script>   