@model City
@{
    ViewData["Title"] = "Редактирование записи о городе";
}

<div class="editPage">
    
    @await Html.PartialAsync("../Edit/_EditButtonMenuPartial")

    <div class="editHeader">
        
        @* для CKEditor 4 *@
        <script src="~/js/ckeditor4/ckeditor.js"></script>

        <form asp-controller="Cities" asp-action="SaveCity" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CountryId" />
            <input type="hidden" asp-for="DateAdded" />
            <input type="hidden" asp-for="TitleImagePath" />
            <div>
                <div asp-validation-summary="All"></div>
                <div class="displayFlexCol">
                    <label asp-for="Name"></label>
                    <input type="text" asp-for="Name" />
                    <span asp-validation-for="Name"></span>
                </div>
                <div class="check-isCapital">
                    <label asp-for="isCapital"></label>
                    <input asp-for="isCapital" type="checkbox" checked="@Model.isCapital" />
                </div>
                <div class="displayFlexCol">
                    <label asp-for="ShortDescription"></label>
                    <input type="text" asp-for="ShortDescription" />
                    <span asp-validation-for="ShortDescription"></span>
                </div>
                <div class="displayFlexCol">
                    <label asp-for="LocalDescription"></label>
                    <input type="text" asp-for="LocalDescription" />
                    <span asp-validation-for="LocalDescription"></span>
                </div>
                <div class="displayFlexCol">
                    <label asp-for="FullDescription"></label>
                    <textarea asp-for="FullDescription" rows="20" cols="100"></textarea>
                    <span asp-validation-for="FullDescription"></span>
                </div>
                <div class="displayFlexCol">
                    <label asp-for="TitleImagePath"></label>
                    <h4>@Model.TitleImagePath</h4>
                    <div class="titleImage">
                        <img src="@Model.TitleImagePath" alt="Титульная картинка горорда" align="left" width="50%" />
                    </div>
                    <input type="file" asp-for="TitleImagePath" accept="image/*" />
                    <span asp-validation-for="TitleImagePath"></span>
                </div>
                <input type="submit" value="Сохранить" />
            </div>
        </form>
    </div>
</div>
<script>
    var newCKEdit = CKEDITOR.replace('FullDescription');
</script>