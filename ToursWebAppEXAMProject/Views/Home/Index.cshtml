@model NewsAndBlogsViewModel
@{
    ViewData["Title"] = "Главная страница";
}

<div class="homePage">

    @await Html.PartialAsync("_HomeButtonMenuPartial")

    <div class="homeHeader">
        <h1 class="title">Домашняя страница сайта:</h1><br />
        <hr class="horizontal-line" /><br />

        <div class="displayFlex row">
            <div class="col-6">

                @if (Model.AllNews == null || !Model.AllNews.Any())
                {
                    <div>
                        <h3 class="title marginTop2">Извините, но новостей в БД пока нет</h3>
                    </div>
                }
                else
                {
                    @foreach (var newItem in Model.AllNews)
                    {
                        <div class="item">
                            <div class="titleImage">
                                <img src="@newItem.TitleImagePath" alt="@newItem.TitleImagePath">
                            </div>
                            <div>
                                <h2>@newItem.Name</h2>
                            </div>
                            <div>
                                <h4>@newItem.ShortDescription</h4>
                            </div>
                            <div class="dateAdded">
                                <h4>@newItem.DateAdded</h4>
                                <a asp-controller="News" asp-action="GetNews" asp-route-id="@newItem.Id">Подробнее ...</a>
                            </div>
                        </div>
                    }
                }
            </div>
            <div class="col-6">
                @if (Model.AllBlogs == null || !Model.AllBlogs.Any())
                {
                    <div>
                        <h3 class="title marginTop2">Извините, но блогов в БД пока нет</h3>
                    </div>
                }
                else
                {
                    @foreach (var blog in Model.AllBlogs)
                    {
                        <div class="item">
                            <div class="titleImage">
                                <img src="@blog.TitleImagePath" alt="@blog.TitleImagePath">
                            </div>
                            <div>
                                <h2>@blog.Name</h2>
                            </div>
                            <div>
                                <h4>@blog.ShortDescription</h4>
                            </div>
                            <div class="dateAdded">
                                <h4>@blog.DateAdded</h4>
                                <a asp-controller="Blogs" asp-action="GetBlog" asp-route-id="@blog.Id">Подробнее ...</a>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>


